# Supabase (R1 auth, R2 persistence). Create a project at supabase.com and fill these.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role — server only, used by the resolve-battle Edge Function (R22). NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Web Push (R34-R36) — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
